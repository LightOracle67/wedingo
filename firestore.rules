rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidUsername(value) {
      return value is string
        && value.size() >= 1
        && value.size() <= 50
        && value.matches('^[a-zA-Z0-9]+$');
    }

    function isSafeText(value) {
      return value is string
        && !value.matches('.*[<>&\"\'\\\\].*')
        && value.size() <= 5000;
    }

    function isValidInvitationData() {
      let data = request.resource.data;
      return data.keys().hasAll(['firstName', 'secondName', 'weddingDay', 'weddingMonth', 'weddingYear', 'weddingHour', 'weddingMinute'])
        && data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100 && isSafeText(data.firstName)
        && data.secondName is string && data.secondName.size() > 0 && data.secondName.size() <= 100 && isSafeText(data.secondName)
        && data.inviteMessage is string && data.inviteMessage.size() <= 500 && isSafeText(data.inviteMessage)
        && data.weddingPlace is string && data.weddingPlace.size() <= 300 && isSafeText(data.weddingPlace)
        && data.weddingDay is string && data.weddingDay.matches('^(0?[1-9]|[12][0-9]|3[01])$')
        && data.weddingMonth is string
        && data.weddingYear is string && data.weddingYear.matches('^[12][0-9]{3}$')
        && data.weddingHour is string && data.weddingHour.matches('^([01]?[0-9]|2[0-3])$')
        && data.weddingMinute is string && data.weddingMinute.matches('^[0-5]?[0-9]$')
        && data.theme in ['golden', 'forest', 'rose', 'linen-soft', 'blush-pearl', 'lavender-mist', 'champagne-bubble', 'amber-night', 'onyx-gold', 'midnight-royal', 'burgundy-velvet', 'sapphire-night', 'emerald-grove', 'plum-twilight']
        && data.adminUsername is string && isValidUsername(data.adminUsername)
        && data.weddingSchedule is string && data.weddingSchedule.size() <= 2000
        && (!data.keys().hasAny(['weddingDressCode']) || (data.weddingDressCode is string && data.weddingDressCode.size() <= 200))
        && (!data.keys().hasAny(['backgroundImage']) || (data.backgroundImage is string && data.backgroundImage.size() <= 700000))
        && (!data.keys().hasAny(['backgroundImageLabel']) || (data.backgroundImageLabel is string && data.backgroundImageLabel.size() <= 200))
        && (!data.keys().hasAny(['backgroundImageSource']) || (data.backgroundImageSource is string && data.backgroundImageSource.size() <= 50))
        && (!data.keys().hasAny(['weddingLatitude']) || (data.weddingLatitude is string && data.weddingLatitude.size() <= 20))
        && (!data.keys().hasAny(['weddingLongitude']) || (data.weddingLongitude is string && data.weddingLongitude.size() <= 20));
    }

    match /publicConfig/invitation {
      allow read: if true;
      allow create: if (!exists(/databases/$(database)/documents/publicConfig/invitation)
        && request.auth == null
        && isValidInvitationData());
      allow update: if isValidInvitationData()
        && (
          request.auth != null
          || (
            request.resource.data.adminUsername is string
            && isValidUsername(request.resource.data.adminUsername)
          )
        );
      allow delete: if false;
    }

    match /setupTokens/{tokenId} {
      allow create: if !exists(/databases/$(database)/documents/setupTokens/$(tokenId))
        && (
          (request.resource.data.keys().hasOnly(['used', 'createdAt', 'username'])
            && request.resource.data.used == false)
          ||
          (request.resource.data.keys().hasOnly(['used', 'createdAt', 'autoGen'])
            && request.resource.data.used == false
            && request.resource.data.autoGen == true)
        );
      allow read: if resource.data.used == false;
      allow update: if resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.keys().hasAll(['used', 'username', 'createdAt', 'usedAt'])
        && request.resource.data.username is string
        && isValidUsername(request.resource.data.username);
      allow delete: if false;
    }

    match /rsvpResponses/{responseId} {
      allow create: if request.resource.data.keys().hasAll(['guestName', 'attendance', 'companions', 'note', 'submittedAt'])
        && request.resource.data.guestName is string
        && request.resource.data.guestName.size() > 0
        && request.resource.data.guestName.size() <= 120
        && isSafeText(request.resource.data.guestName)
        && request.resource.data.attendance in ['yes', 'no']
        && request.resource.data.companions is int
        && request.resource.data.companions >= 0
        && request.resource.data.companions <= 10
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 240
        && isSafeText(request.resource.data.note);

      allow read: if request.auth != null;
      allow update: if false;
      allow delete: if request.auth != null;
    }
  }
}
