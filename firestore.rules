rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email in ['adriancl2001@gmail.com'];
    }

    function sessionExists(tokenId) {
      return exists(/databases/$(database)/documents/invitations/$(tokenId));
    }

    function hasActiveSession(tokenId) {
      return sessionExists(tokenId)
        && get(/databases/$(database)/documents/invitations/$(tokenId)).data.activeSession is timestamp;
    }

    function isAdminOf(tokenId) {
      return request.auth != null
        && hasActiveSession(tokenId);
    }

    function isSafeText(value) {
      return value is string
        && !value.matches('.*[<>\"\'\\\\`].*')
        && !value.matches('(?i).*javascript:.*')
        && value.size() <= 5000;
    }

    function isValidInvitationWrite(data) {
      return data.keys().hasAll(['firstName', 'secondName', 'weddingDay', 'weddingMonth', 'weddingYear', 'weddingHour', 'weddingMinute'])
        && data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100 && isSafeText(data.firstName)
        && data.secondName is string && data.secondName.size() > 0 && data.secondName.size() <= 100 && isSafeText(data.secondName)
        && data.weddingDay is string && data.weddingDay.matches('^(0?[1-9]|[12][0-9]|3[01])$')
        && data.weddingMonth is string && data.weddingMonth.matches('^(enero|febrero|marzo|abril|mayo|junio|julio|agosto|septiembre|octubre|noviembre|diciembre)$')
        && data.weddingYear is string && data.weddingYear.matches('^[12][0-9]{3}$')
        && data.weddingHour is string && data.weddingHour.matches('^([01]?[0-9]|2[0-3])$')
        && data.weddingMinute is string && data.weddingMinute.matches('^[0-5]?[0-9]$')
        && data.theme in ['golden', 'forest', 'rose', 'linen-soft', 'blush-pearl', 'lavender-mist', 'champagne-bubble', 'amber-night', 'onyx-gold', 'midnight-royal', 'burgundy-velvet', 'sapphire-night', 'emerald-grove', 'plum-twilight', 'rainbow', 'trans', 'nonbinary', 'lesbian', 'bi', 'pan', 'ace'];
    }

    match /invitations/{tokenId} {
      allow read: if true;
      allow create: if isValidInvitationWrite(request.resource.data)
        && (request.auth != null
          || !exists(/databases/$(database)/documents/invitations/$(tokenId)));
      allow update: if isValidInvitationWrite(request.resource.data)
        && (request.auth != null || hasActiveSession(tokenId));
      allow update: if request.auth == null
        && request.resource.data.activeSession is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeSession']);
      allow delete: if isSuperAdmin();

      /** Subcolección de imágenes de la galería (cifradas). */
      match /gallery/{imageId} {
        allow read: if true;
        allow create: if hasActiveSession(tokenId) && request.resource.data.data is string;
        allow update: if hasActiveSession(tokenId)
          && request.resource.data.keys().hasOnly(['description'])
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 200;
        allow delete: if isSuperAdmin() || hasActiveSession(tokenId);
      }
    }

    match /setupTokens/{tokenId} {
      allow get: if true;
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin()
        || (!exists(/databases/$(database)/documents/setupTokens/$(tokenId))
          && (
            (request.resource.data.keys().hasOnly(['used', 'createdAt', 'username'])
              && request.resource.data.used == false)
            ||
            (request.resource.data.keys().hasOnly(['used', 'createdAt', 'autoGen', 'inviteToken'])
              && request.resource.data.used == false
              && request.resource.data.autoGen == true
              && hasActiveSession(request.resource.data.inviteToken))
          ));
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /rsvpResponses/{responseId} {
      allow create: if request.resource.data.keys().hasAll(['guestName', 'attendance', 'dietaryInfo', 'submittedAt', 'inviteToken', 'privacyConsent'])
        && request.resource.data.guestName is string
        && request.resource.data.guestName.size() > 0
        && request.resource.data.guestName.size() <= 120
        && isSafeText(request.resource.data.guestName)
        && request.resource.data.attendance in ['yes', 'no']
        && request.resource.data.dietaryInfo is string
        && request.resource.data.dietaryInfo.size() <= 4000
        && request.resource.data.inviteToken is string
        && hasActiveSession(request.resource.data.inviteToken)
        && request.resource.data.privacyConsent == true
        && (request.resource.data.keys().hasOnly(['guestName', 'attendance', 'dietaryInfo', 'submittedAt', 'inviteToken', 'privacyConsent', 'privacyConsentAt', 'birthDate', 'parentalConsent', 'menuSelection', 'healthConsent'])
          || request.resource.data.keys().hasOnly(['guestName', 'attendance', 'dietaryInfo', 'submittedAt', 'inviteToken', 'privacyConsent', 'privacyConsentAt', 'birthDate', 'parentalConsent', 'menuSelection']));

      allow read: if isSuperAdmin()
        || (resource.data.inviteToken is string
          && hasActiveSession(resource.data.inviteToken));

      allow update: if request.resource.data.attendance in ['yes', 'no']
        && request.resource.data.dietaryInfo is string
        && request.resource.data.inviteToken is string
        && hasActiveSession(resource.data.inviteToken)
        && request.resource.data.privacyConsent == true
        && request.resource.data.keys().hasOnly(['attendance', 'dietaryInfo', 'privacyConsent', 'privacyConsentAt', 'healthConsent', 'birthDate', 'parentalConsent', 'menuSelection', 'guestName', 'submittedAt', 'inviteToken']);

      allow delete: if isSuperAdmin()
        || (resource.data.inviteToken is string
          && hasActiveSession(resource.data.inviteToken));
    }
  }
}
