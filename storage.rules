rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /invitations/{token}/{allPaths=**} {
      function hasActiveSession() {
        return firestore.exists(/databases/(default)/documents/invitations/$(token))
          && firestore.get(/databases/(default)/documents/invitations/$(token)).data.activeSession is timestamp;
      }
      allow read: if request.auth != null
        || hasActiveSession();
      allow write: if (request.auth != null
        || hasActiveSession())
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        || hasActiveSession();
    }
  }
}
